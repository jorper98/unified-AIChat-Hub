# ==========================================
# Unified Chat Hub Environment Configuration
# ==========================================
# Copy this file to .env and update the values for your environment.
# NEVER commit your actual .env file to version control.

# ==========================================
# 1. API Keys & Database
# ==========================================
# OpenRouter API Key (Optional fallback if users don't set their own)
OPENROUTER_API_KEY=sk-or-v1-your_actual_token_string_here

# MongoDB Connection String (Local or Cloud)
MONGODB_URI=mongodb://localhost:27017/chathub

# ==========================================
# 2. Authentication & Security (NEW)
# ==========================================
# Secret key for signing JWT authentication tokens. 
# MUST be a long, random string in production.
JWT_SECRET=your-super-secret-jwt-key-change-in-production-must-be-long

# 32-character string for AES-256-GCM encryption of user API keys at rest.
# MUST be exactly 32 characters long.
ENCRYPTION_KEY=exactly-32-bytes-long-key-required!!

# ==========================================
# 3. Email Configuration (SMTP for Verification)
# ==========================================
# Required for user registration email verification and password resets.
# For Gmail: Use an "App Password" generated from your Google Account security settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Unified Chat Hub" <no-reply@unifiedchat.com>

# ==========================================
# 4. Application & Network Settings
# ==========================================
# Public URL of the application (used for OpenRouter rate-limit attribution and absolute URLs)
# Update the port if you change the docker-compose port mapping (default is 3031)
NEXT_PUBLIC_APP_URL=http://localhost:3031

# Host port for running tests from the host machine 
# (matches the left side of docker-compose port mapping)
HOST_PORT=3031

# ==========================================
# 5. Context & Localization
# ==========================================
# Timezone for date/time display (IANA format)
TIMEZONE=America/Phoenix

# Location for weather injection (city name, zip code, or coordinates)
# Leave empty to disable weather. You can ask about any location: "weather in Paris"
WEATHER_LOCATION=Phoenix, AZ

# ==========================================
# 6. Over-The-Air (OTA) Updates (Optional)
# ==========================================
# URL to the deployment zip file. 
# If left blank, the app will automatically fetch the latest release asset from the official GitHub repository.
# Override this if you are using a fork or a custom release hosting location.
UPDATE_ZIP_URL=https://github.com/jorper98/unified-AIChat-Hub/releases/latest/download/unified-chat-deploy-latest.zip

# ==========================================
# 7. Admin Migration Defaults (Optional)
# ==========================================
# Default credentials used by `scripts/migrate-admin.ts` or `scripts/reset-admin.ts`
# Leave commented out to use script defaults (admin@localhost / admin123456)
# ADMIN_EMAIL=admin@localhost
# ADMIN_PASSWORD=admin123456
# ADMIN_NAME=Admin
